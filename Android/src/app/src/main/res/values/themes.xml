<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Main App Theme -->
    <style name="Theme.NexusAI" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash Screen Theme -->
    <style name="Theme.NexusAI.SplashScreen" parent="Theme.SplashScreen">
        <!-- Need to match surfaceLight in Colors.kt -->
        <item name="windowSplashScreenBackground">#FFFFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_screen_animated_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.NexusAI</item>
    </style>

    <!-- OSS Licenses Theme -->
    <style name="Theme.NexusAI.OssLicenses" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>

</resources>
